{
  "name": "mevn-orm",
  "version": "4.2.1",
  "private": false,
  "description": "simple ORM for express js",
  "keywords": [
    "ORM",
    "express",
    "Mysql",
    "mevn",
    "database",
    "orm",
    "orm-express",
    "orm-mysql"
  ],
  "homepage": "https://github.com/StanleyMasinde/mevn-orm#readme",
  "bugs": {
    "url": "https://github.com/StanleyMasinde/mevn-orm/issues",
    "email": "stanleymasinde1@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StanleyMasinde/mevn-orm.git"
  },
  "license": "MIT",
  "author": "Stanley Masinde <hello@stanleymasinde.com> (https://stanleymasinde.github.io)",
  "contributors": [
    {
      "name": "Stanley Masinde",
      "email": "hello@stanleymasinde.com"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "pretest": "node --import tsx initDb.ts",
    "test": "vitest run",
    "init:db": "node --import tsx initDb.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "node --import tsx scripts/migrate.ts latest",
    "migrate:make": "node --import tsx scripts/migrate.ts make",
    "migrate:rollback": "node --import tsx scripts/migrate.ts rollback",
    "migrate:list": "node --import tsx scripts/migrate.ts list",
    "migrate:version": "node --import tsx scripts/migrate.ts version",
    "lint": "eslint .",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "knex": "^3.2.9",
    "sqlite3": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "knex": "^3.0.0",
    "mysql2": "^3.9.3"
  },
  "peerDependenciesMeta": {
    "knex": {
      "optional": false
    }
  },
  "packageManager": "pnpm@10.33.0"
}
